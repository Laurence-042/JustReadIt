{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build mem_scan.dll",
            "type": "shell",
            "command": "${workspaceFolder}\\.vscode\\build_mem_scan.bat",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": {
                "owner": "msvc",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.+)\\((\\d+)\\)\\s*:\\s*(error|warning)\\s+(C\\d+):\\s*(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            }
        }
    ]
}
