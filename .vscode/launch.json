{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Main Window",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Main Window (no debug)",
            "type": "debugpy",
            "request": "launch",
            "noDebug": true,
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": [],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Debug UI",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": ["--debug"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run UI (no debug)",
            "type": "debugpy",
            "request": "launch",
            "noDebug": true,
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": ["--debug"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest (all)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest (correction dataset — external CSV)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_correction_dataset.py",
                "--correction-samples=${input:correctionSamplesPath}",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "correctionSamplesPath",
            "type": "promptString",
            "description": "correction_samples CSV 文件路径（从数据标注导出）",
            "default": "${workspaceFolder}/correction_samples_export.csv"
        }
    ]
}
