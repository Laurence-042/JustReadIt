{
    "version": "0.2.0",
    // PYDEVD_USE_FRAME_EVAL=NO: 禁用 debugpy 的 frame evaluation 模式，回退到 sys.settrace。
    // Shiboken（PySide6 绑定层）在 import hook 内部使用 KeyboardInterrupt 做流程控制，
    // frame eval 模式会在 try/except 边界之外拦截该异常并重新抛出，导致调试启动崩溃。
    // sys.settrace 遵守标准异常传播语义，Shiboken 可以正常吞掉自己抛出的 KeyboardInterrupt。
    "configurations": [
        {
            "name": "Main Window",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_USE_FRAME_EVAL": "NO"
            }
        },
        {
            "name": "Main Window (no debug)",
            "type": "debugpy",
            "request": "launch",
            "noDebug": true,
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": [],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Debug UI",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": ["--debug"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_USE_FRAME_EVAL": "NO"
            }
        },
        {
            "name": "Run UI (no debug)",
            "type": "debugpy",
            "request": "launch",
            "noDebug": true,
            "preLaunchTask": "Build mem_scan.dll",
            "program": "${workspaceFolder}/main.py",
            "args": ["--debug"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "pytest (all)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_USE_FRAME_EVAL": "NO"
            }
        },
        {
            "name": "pytest (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_USE_FRAME_EVAL": "NO"
            }
        },
        {
            "name": "pytest (correction dataset — external CSV)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_correction_dataset.py",
                "--correction-samples=${input:extraCorrectionSamplesPath}",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_USE_FRAME_EVAL": "NO"
            }
        }
    ],
    "inputs": [
        {
            "id": "correctionSamplesPath",
            "type": "promptString",
            "description": "correction_samples CSV 文件路径（从数据标注导出）",
            "default": "${workspaceFolder}/correction_samples_export.csv"
        },
        {
            "id": "extraCorrectionSamplesPath",
            "type": "promptString",
            "description": "extra_correction_samples CSV 文件路径（从数据标注导出）",
            "default": "${workspaceFolder}/tests/extra/correction_samples_export.csv"
        }
    ]
}
